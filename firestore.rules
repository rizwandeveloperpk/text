rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId} {
      allow read, update, create: if request.auth != null && request.auth.uid == userId;
    }

    match /profiles/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      // The client creates its OWN profile doc once, on first login/register
      // (see ensureUserDocument in lib/firebase/client.ts) — that's a
      // Firestore "create" (no existing doc), which this allows. Everything
      // after that (credits, plan) is only ever mutated server-side via the
      // Admin SDK, so update/delete stay blocked for the client.
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update, delete: if false;
    }

    match /conversions/{conversionId} {
      allow read, update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if false; // conversions are only created server-side (Admin SDK) after OCR
    }

    match /queries/{queryId} {
      // Contact form submissions: written by /api/contact via the Admin SDK
      // (so guests can submit without needing to be authenticated to write
      // to Firestore directly), and only ever read/managed from /admin/queries,
      // also via the Admin SDK. Never accessible directly from the client.
      allow read, write: if false;
    }

    // Admin-only collections/dashboards should be read via the Admin SDK on
    // the server (see app/admin/*), never directly from the client.
  }
}
